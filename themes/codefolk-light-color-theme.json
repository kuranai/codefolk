  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#999999",
        "fontStyle": ""
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#1794FAF0"
      }
    },
    {
      "name": "Numbers",
      "scope": "constant.numeric",
      "settings": {
        "foreground": "#0025F5"
      }
    },
    {
      "name": "Built-in constants",
      "scope": "constant.language",
      "settings": {
        "foreground": "#DE5CFF"
      }
    },
    {
      "name": "User constants",
      "scope": [
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#AE81FF"
      }
    },
    {
      "name": "Keywords",
      "scope": "keyword",
      "settings": {
        "foreground": "#FF3333",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#EB5086"
      }
    },
    {
      "name": "Storage types",
      "scope": "storage.type",
      "settings": {
        "foreground": "#0088FF"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#3B3347"
      }
    },
    {
      "name": "Functions",
      "scope": "entity.name.function",
      "settings": {
        "foreground": "#1DA11D"
      }
    },
    {
      "name": "Library functions",
      "scope": "support.function",
      "settings": {
        "foreground": "#FFCD03"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#124CFA"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#3B3347"
      }
    },
    {
      "name": "Parameters",
      "scope": "variable.parameter",
      "settings": {
        "foreground": "#FD8B19"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.property",
        "support.type.property-name",
        "meta.object-literal.key",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#AE81FF"
      }
    },
    {
      "name": "Language variables",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#FF960D"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#F92672"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#AE81FF"
      }
    },
    {
      "name": "CSS values",
      "scope": [
        "support.constant.property-value",
        "constant.other.color",
        "support.constant.font-name"
      ],
      "settings": {
        "foreground": "#1794FA"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json",
        "string.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#AE81FF"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#FF3333",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": "markup.bold",
      "settings": {
        "foreground": "#3B3347",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": "markup.italic",
      "settings": {
        "foreground": "#3B3347",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "meta.link.inline.markdown"
      ],
      "settings": {
        "foreground": "#1459B8"
      }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#1794FA"
      }
    },
    {
      "name": "Diff inserted",
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#277A38"
      }
    },
    {
      "name": "Diff deleted",
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#C62828"
      }
    },
    {
      "name": "Diff changed",
      "scope": "markup.changed",
      "settings": {
        "foreground": "#7A5D00"
      }
    },
    {
      "name": "Elixir atoms",
      "scope": [
        "constant.other.symbol.elixir",
        "constant.other.symbol.ruby"
      ],
      "settings": {
        "foreground": "#AE81FF"
      }
    },
    {
      "name": "Elixir module aliases",
      "scope": [
        "entity.name.type.module.elixir",
        "support.class.elixir"
      ],
      "settings": {
        "foreground": "#124CFA"
      }
    },
    {
      "name": "HEEx components",
      "scope": [
        "entity.name.tag.heex",
        "support.class.component.heex",
        "entity.name.tag.html"
      ],
      "settings": {
        "foreground": "#F92672"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#C62828"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#124CFA",
    "class.declaration": {
      "foreground": "#124CFA",
      "bold": true
    },
    "comment": {
      "foreground": "#999999",
      "italic": false
    },
    "decorator": "#A02F6F",
    "enum": "#124CFA",
    "enumMember": "#AE81FF",
    "event": "#A02F6F",
    "function": "#1DA11D",
    "function.declaration": {
      "foreground": "#1DA11D",
      "bold": true
    },
    "interface": "#124CFA",
    "keyword": "#FF3333",
    "label": "#A02F6F",
    "macro": "#70409B",
    "method": "#1DA11D",
    "method.declaration": {
      "foreground": "#1DA11D",
      "bold": true
    },
    "namespace": "#124CFA",
    "number": "#0025F5",
    "operator": "#3B3347",
    "parameter": "#FD8B19",
    "property": "#AE81FF",
    "regexp": "#B45309",
    "string": "#1794FA",
    "struct": "#124CFA",
    "type": "#124CFA",
    "typeParameter": "#124CFA",
    "variable": "#3B3347",
    "variable.readonly": "#AE81FF",
    "*.defaultLibrary": "#124CFA",
    "*.deprecated": {
      "foreground": "#77707F",
      "fontStyle": "strikethrough"
    }
  }
}

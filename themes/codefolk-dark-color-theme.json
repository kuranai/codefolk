  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#A3ACB9",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "punctuation.definition.string"
      ],
      "settings": {
        "foreground": "#C3E88D"
      }
    },
    {
      "name": "Numbers and constants",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other"
      ],
      "settings": {
        "foreground": "#F78C6C"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#C792EA"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#B9B9BD"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#82AAFF"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#FFCB6B"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other.readwrite",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#E7E7E7"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.property",
        "support.type.property-name",
        "meta.object-literal.key",
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#FEDD6E"
      }
    },
    {
      "name": "Language variables",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#F78C6C"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#F07178"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name",
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#FEDD6E"
      }
    },
    {
      "name": "CSS values",
      "scope": [
        "support.constant.property-value",
        "constant.other.color",
        "support.constant.font-name"
      ],
      "settings": {
        "foreground": "#C3E88D"
      }
    },
    {
      "name": "JSON keys",
      "scope": [
        "support.type.property-name.json",
        "string.json support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#FEDD6E"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#C792EA",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": "markup.bold",
      "settings": {
        "foreground": "#E7E7E7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": "markup.italic",
      "settings": {
        "foreground": "#E7E7E7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "meta.link.inline.markdown"
      ],
      "settings": {
        "foreground": "#82AAFF"
      }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#C3E88D"
      }
    },
    {
      "name": "Diff inserted",
      "scope": "markup.inserted",
      "settings": {
        "foreground": "#C3E88D"
      }
    },
    {
      "name": "Diff deleted",
      "scope": "markup.deleted",
      "settings": {
        "foreground": "#F07178"
      }
    },
    {
      "name": "Diff changed",
      "scope": "markup.changed",
      "settings": {
        "foreground": "#FFCB6B"
      }
    },
    {
      "name": "Elixir atoms",
      "scope": [
        "constant.other.symbol.elixir",
        "constant.other.symbol.ruby"
      ],
      "settings": {
        "foreground": "#C792EA"
      }
    },
    {
      "name": "Elixir module aliases",
      "scope": [
        "entity.name.type.module.elixir",
        "support.class.elixir"
      ],
      "settings": {
        "foreground": "#FFCB6B"
      }
    },
    {
      "name": "HEEx components",
      "scope": [
        "entity.name.tag.heex",
        "support.class.component.heex",
        "entity.name.tag.html"
      ],
      "settings": {
        "foreground": "#F07178"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#F07178"
      }
    }
  ],
  "semanticTokenColors": {
    "class": "#FFCB6B",
    "class.declaration": {
      "foreground": "#FFCB6B",
      "bold": true
    },
    "comment": {
      "foreground": "#A3ACB9",
      "italic": true
    },
    "decorator": "#FF9CAC",
    "enum": "#FFCB6B",
    "enumMember": "#FEDD6E",
    "event": "#FF9CAC",
    "function": "#82AAFF",
    "function.declaration": {
      "foreground": "#82AAFF",
      "bold": true
    },
    "interface": "#FFCB6B",
    "keyword": "#C792EA",
    "label": "#FF9CAC",
    "macro": "#C792EA",
    "method": "#82AAFF",
    "method.declaration": {
      "foreground": "#82AAFF",
      "bold": true
    },
    "namespace": "#FFCB6B",
    "number": "#F78C6C",
    "operator": "#B9B9BD",
    "parameter": "#E7E7E7",
    "property": "#FEDD6E",
    "regexp": "#F78C6C",
    "string": "#C3E88D",
    "struct": "#FFCB6B",
    "type": "#FFCB6B",
    "typeParameter": "#FFCB6B",
    "variable": "#E7E7E7",
    "variable.readonly": "#F78C6C",
    "*.defaultLibrary": "#89DDFF",
    "*.deprecated": {
      "foreground": "#8D8D92",
      "fontStyle": "strikethrough"
    }
  }
}
